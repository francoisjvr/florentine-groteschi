# Florentine Brainrot Burn Agent env
# Copy to agents/burn-agent/.env on the deployment host. Do not commit the real file.

# Contract / chain
CHAIN_ID=1
CAIP2=eip155:1
RPC_URL=
BRAINROT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Safety defaults
# Keep true until the Privy wallet is created, admin-enabled, funded, and tested.
BURN_AGENT_DRY_RUN=true
BURN_AGENT_LOG_FILE=agents/burn-agent/logs/burn-agent.jsonl
BURN_AGENT_QUEUE_FILE=agents/burn-agent/queue.json
BURN_AGENT_POLL_SECONDS=60
BURN_AGENT_WAIT_FOR_RECEIPT=true

# Privy server wallet credentials
# Create with: npm run agent:setup-privy
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WALLET_ID=
PRIVY_WALLET_ADDRESS=
PRIVY_SPONSOR_GAS=false

# OpenSea marketplace data, reserved for future policy monitoring.
OPENSEA_API_KEY=
OPENSEA_COLLECTION_SLUG=florentine-brainrot

# X/Twitter announcements. Missing creds force Twitter dry-run.
TWITTER_DRY_RUN=true
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_ANNOUNCE_BEFORE=true
TWITTER_ANNOUNCE_AFTER=true
